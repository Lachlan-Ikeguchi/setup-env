#!/usr/bin/env bash

# Without flags: create a branch and a worktree linked to it
# With --rebase: rebase a worktree branch into the main repository and clean up
# With --merge: merge a worktree branch into the main repository and clean up
# With --continue: clean up after resolving merge/rebase conflicts
# With -d: delete a worktree for a given branch

usage() {
    cat <<EOF
Usage: worktree [OPTIONS] <branch>

Create a branch and a worktree linked to it, delete a worktree, or rebase/merge and clean up.

Options:
  -r             Create local tracking branch from origin/<branch> (requires fetch).
                 Mutually exclusive with -e and -d
  -e             Create a worktree from an existing local branch.
                 Mutually exclusive with -r and -d
  -d             Delete the worktree directory at ../<branch> and clean up empty parent directories.
                 Mutually exclusive with -r, -e, --rebase, --merge, --continue
  --rebase       Rebase the branch into master and clean up worktree (requires --confirm)
  --merge        Merges the branch into master and clean up worktree (requires --confirm)
  --continue     Clean up after resolving merge/rebase conflicts (requires --confirm)
  --confirm      Confirm the rebase, merge, or continue operation (used with --rebase, --merge, --continue)
  -h             Show this help message

Without switches: creates a new local branch from current HEAD.

Create mode (default):
  1. Creates a local branch (-e skips this step)
  2. Creates a worktree at ../<branch>
  3. Starts a new bash shell in the new worktree

Delete mode (-d):
  1. Deletes the worktree at ../<branch>
  2. Cleans up empty parent directories

Rebase mode (--rebase):
  1. Rebases <branch> onto master/main/trunk
  2. Deletes the worktree directory at ../<branch> and empty parent directories
  3. Deletes the local branch
  4. Deletes the remote branch (origin/<branch>)
  Note: dry-run by default, requires --confirm to actually perform actions

Merge mode (--merge):
  1. Merges <branch> onto master/main/trunk
  2. Deletes the worktree directory at ../<branch> and empty parent directories
  3. Deletes the local branch
  4. Deletes the remote branch (origin/<branch>)
  Note: dry-run by default, requires --confirm to actually perform actions

Continue mode (--continue):
  1. Deletes the worktree directory at ../<branch> and empty parent directories
  2. Deletes the local branch
  3. Deletes the remote branch (origin/<branch>)
  Note: Use after manually resolving rebase/merge conflicts. Requires --confirm.
EOF
}

rebase_mode=false
merge_mode=false
continue_mode=false
confirm=false
remote=false
existing=false
delete_mode=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --rebase) rebase_mode=true ;;
        --merge) merge_mode=true ;;
        --continue) continue_mode=true ;;
        --confirm) confirm=true ;;
        -d) delete_mode=true ;;
        -r) remote=true ;;
        -e) existing=true ;;
        -h) usage; exit 0 ;;
        *) break ;;
    esac
    shift
done

if [[ -z "$1" ]]; then
    echo "Error: provide branch name" >&2
    usage >&2
    exit 1
fi

branch="$1"

# Check if we're in the main repo (has .git/) not a worktree (has .git file)
if [[ -f ".git" ]]; then
    echo "Error: must be called from the main repository, not a worktree" >&2
    exit 1
fi

if [[ ! -d ".git" ]]; then
    echo "Error: not a git repository" >&2
    exit 1
fi

if [[ "$rebase_mode" = true && "$merge_mode" = true ]]; then
    echo "Error: cannot use --rebase and --merge together" >&2
    usage >&2
    exit 1
fi

if [[ "$rebase_mode" = true && "$continue_mode" = true ]]; then
    echo "Error: cannot use --rebase and --continue together" >&2
    usage >&2
    exit 1
fi

if [[ "$merge_mode" = true && "$continue_mode" = true ]]; then
    echo "Error: cannot use --merge and --continue together" >&2
    usage >&2
    exit 1
fi

if [[ "$rebase_mode" || "$merge_mode" || "$continue_mode" ]]; then
    if $continue_mode && [[ "$confirm" != true ]]; then
        echo "Error: --continue requires --confirm" >&2
        usage >&2
        exit 1
    fi

    if [[ "$remote" = true || "$existing" = true || "$delete_mode" = true ]]; then
        echo "Error: cannot use -r, -e, or -d with --rebase, --merge, or --continue" >&2
        usage >&2
        exit 1
    fi

    # Determine the main branch (master, main, or trunk)
    main_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|^refs/remotes/origin/||')
    if [[ -z "$main_branch" ]]; then
        for candidate in main master trunk; do
            if git show-ref --quiet refs/heads/$candidate; then
                main_branch=$candidate
                break
            fi
        done
    fi

    if [[ -z "$main_branch" ]]; then
        echo "Error: cannot determine main branch (tried origin/HEAD, main, master, trunk)" >&2
        exit 1
    fi

    # Check that the branch exists
    if ! git show-ref --quiet refs/heads/$branch; then
        echo "Error: branch '$branch' does not exist" >&2
        exit 1
    fi

    # Worktree is expected at ../<branch>
    worktree_path="../$branch"

    if $confirm; then
        if ! git worktree remove "$worktree_path" 2>/dev/null; then
            echo "Error: could not remove worktree" >&2
            exit 1
        fi

        if $rebase_mode; then
            if ! git rebase "$main_branch" "$branch"; then
                echo "Error: rebase failed" >&2
                exit 1
            fi
        elif $merge_mode; then
            if ! git merge "$branch"; then
                echo "Error: merge failed" >&2
                exit 1
            fi
        fi

        # Clean up empty parent directories
        path_to_clean="$(dirname "$worktree_path")"
        while [[ "$path_to_clean" != .. && "$path_to_clean" != . ]]; do
            rmdir --ignore-fail-on-non-empty "$path_to_clean" 2>/dev/null || break
            path_to_clean="${path_to_clean%/*}"
        done

        if ! git branch -d "$branch"; then
            echo "Error: failed to delete local branch" >&2
            exit 1
        fi

        if ! git push -d "origin" "$branch" 2>/dev/null; then
            echo "Warning: remote branch may not exist or deletion failed."
        fi
    else
        type_str=""
        flag_str=""

        if $rebase_mode; then
            type_str="Rebase"
            flag_str="--rebase"
        elif $merge_mode; then
            type_str="Merge"
            flag_str="--merge"
        elif $continue_mode; then
            type_str="Clean up"
            flag_str="--continue"
        fi

        # Validate worktree exists
        if [[ ! -d "$worktree_path" ]]; then
            echo "Error: worktree directory not found at $worktree_path" >&2
            exit 1
        fi

        echo "=== DRY RUN - No changes will be made ==="
        echo ""
        echo "Would perform the following:"
        if $continue_mode; then
            echo "  1. Delete worktree at $worktree_path and clean up empty parent directories"
            echo "  2. Delete local branch $branch"
            echo "  3. Delete remote branch origin/$branch"
        else
            echo "  1. $type_str $branch onto $main_branch"
            echo "  2. Delete worktree at $worktree_path and clean up empty parent directories"
            echo "  3. Delete local branch $branch"
            echo "  4. Delete remote branch origin/$branch"
        fi
        echo ""
        echo "To execute, run: worktree $flag_str --confirm $branch"
        echo "Warning: ensures no one else is working on this branch - it will be deleted"
    fi
elif $delete_mode; then
    # ============ DELETE MODE ============

    if [[ "$remote" = true || "$existing" = true ]]; then
        echo "Error: cannot use -r or -e with -d" >&2
        usage >&2
        exit 1
    fi

    if [[ "$confirm" = true ]]; then
        echo "Error: --confirm is only used with --rebase, --merge, or --continue" >&2
        usage >&2
        exit 1
    fi

    # Worktree is expected at ../<branch>
    worktree_path="../$branch"

    if ! git worktree remove "$worktree_path" 2>/dev/null; then
        echo "Error: could not remove worktree" >&2
        exit 1
    fi

    # Clean up empty parent directories
    path_to_clean="$(dirname "$worktree_path")"
    while [[ "$path_to_clean" != .. && "$path_to_clean" != . ]]; do
        rmdir --ignore-fail-on-non-empty "$path_to_clean" 2>/dev/null || break
        path_to_clean="${path_to_clean%/*}"
    done

    echo "Deleted worktree at $worktree_path"
else
    # ============ CREATE MODE ============

    if [[ "$remote" = true && "$existing" = true ]]; then
        echo "Error: cannot use switches -r and -e at the same time" >&2
        usage >&2
        exit 1
    fi

    if [[ "$delete_mode" = true ]]; then
        echo "Error: -d cannot be used with create mode" >&2
        usage >&2
        exit 1
    fi

    if [[ "$confirm" = true ]]; then
        echo "Error: --confirm is only used with --rebase, --merge, or --continue" >&2
        usage >&2
        exit 1
    fi

    if [[ "$remote" = true ]]; then
        if ! git fetch origin "$branch:$branch"; then
            echo "Error: failed to create local tracking branch" >&2
            exit 1
        fi
    elif [[ "$existing" != true ]]; then
        if ! git branch "$branch"; then
            echo "Error: failed to create branch" >&2
            exit 1
        fi
        printf "\nRemember to push to create tracking branches in remote\n\n"
    else
        if ! git show-ref --quiet "refs/heads/$branch"; then
            echo "Error: branch '$branch' does not exist locally" >&2
            exit 1
        fi
    fi

    if ! git worktree add "../$branch" "$branch"; then
        echo "Error: failed to create worktree" >&2
        exit 1
    fi

    exec bash -c 'cd "$1"; exec bash' _ "../$branch"
fi
